#!/bin/bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../scripts/lib/vault-resolver.sh"
source "$SCRIPT_DIR/../scripts/lib/extensions-resolver.sh"
source "$SCRIPT_DIR/../scripts/lib/managed-markdown.sh"

NON_INTERACTIVE=0
FORCE_CONFIG=0
FORCE_HERD=0
FULL_CONFIG_RAN=0
CONFIGURATION_GENERATED=0
ENABLE_WORKFLOW_ORCHESTRATION="${AI_SHADOW_ENABLE_WORKFLOW_ORCHESTRATION:-0}"
USE_GEMINI_CONTEXT_MODE="preserve"
GEMINI_CLI_CHECKED=0
GEMINI_CLI_AVAILABLE=0
GEMINI_CLI_WARNED=0

while [[ "$#" -gt 0 ]]; do
    case "${1:-}" in
        --non-interactive)
            NON_INTERACTIVE=1
            ;;
        --force-config)
            FORCE_CONFIG=1
            ;;
        --herd)
            FORCE_HERD=1
            NON_INTERACTIVE=1
            ;;
        --enable-workflow)
            ENABLE_WORKFLOW_ORCHESTRATION=1
            ;;
        --disable-workflow)
            ENABLE_WORKFLOW_ORCHESTRATION=0
            ;;
        --use-gemini)
            USE_GEMINI_CONTEXT_MODE="enable"
            ;;
        --no-use-gemini)
            USE_GEMINI_CONTEXT_MODE="disable"
            ;;
        *)
            echo "Unknown option: $1" >&2
            exit 1
            ;;
    esac
    shift
done

# Build configurator flags once, used in all calls below
if [[ "$FORCE_HERD" -eq 1 ]]; then
    CONFIGURATOR_FLAGS="--herd"
elif [[ "$NON_INTERACTIVE" -eq 1 ]]; then
    CONFIGURATOR_FLAGS="--non-interactive"
else
    CONFIGURATOR_FLAGS=""
fi

DATA_ROOT="$(vault_ensure_data_root)"
PROJECT_ROOT="$(vault_resolve_project_root "$PWD")"
PROJECT_SLUG="$(vault_resolve_project_slug "$PROJECT_ROOT")"
PROJECT_VAULT="$(vault_resolve_project_vault "$PROJECT_ROOT")"
AI_VAULT="$PROJECT_VAULT/.ai"
TEMPLATES_DIR="$SCRIPT_DIR/../templates"

copy_if_missing() {
    local source_path="$1"
    local destination_path="$2"

    if [ ! -e "$destination_path" ]; then
        cp "$source_path" "$destination_path"
    fi
}

rtk_is_available() {
    local version
    version="$(rtk --version 2>/dev/null || true)"
    [[ "$version" == rtk\ * ]]
}

gemini_cli_available() {
    if [ "$GEMINI_CLI_CHECKED" -eq 1 ]; then
        [ "$GEMINI_CLI_AVAILABLE" -eq 1 ]
        return
    fi

    if command -v gemini >/dev/null 2>&1; then
        GEMINI_CLI_AVAILABLE=1
    else
        GEMINI_CLI_AVAILABLE=0
    fi

    GEMINI_CLI_CHECKED=1
    [ "$GEMINI_CLI_AVAILABLE" -eq 1 ]
}

warn_missing_gemini_cli_once() {
    if [ "$GEMINI_CLI_WARNED" -eq 1 ]; then
        return
    fi

    echo "⚠️  Gemini section requested, but \`gemini\` CLI was not found in PATH. Skipping section update."
    GEMINI_CLI_WARNED=1
}

docs_first_section_content() {
    cat <<'EOF_DOCS_FIRST'
Before implementing changes, inspect project-local documentation first:

1. Relevant root markdown files (`*.md` at project root).
2. `.ai/` context (`.ai/rules.md`, `.ai/plans/`, `.ai/docs/`, `.ai/context/`).
3. Any local documentation folders used by this repository.
4. Existing plans, conventions, and architecture notes already present in the repo.

If external library/API details are required and Context7 MCP is available in this environment, use Context7 before making assumptions.
Do not invent APIs, method signatures, configuration keys, or undocumented behavior.
EOF_DOCS_FIRST
}

workflow_orchestration_section_content() {
    cat <<'EOF_WORKFLOW'
Workflow orchestration (optional preset):

1. Default to planning mode for non-trivial tasks.
2. Re-plan immediately when assumptions break.
3. Verify outcomes before marking work done (tests/logs/diffs as applicable).
4. Prefer elegant fixes when complexity is justified; avoid over-engineering simple tasks.
5. Keep task execution autonomous, but grounded in repository evidence.
EOF_WORKFLOW
}

gemini_large_context_section_content() {
    cat <<'EOF_GEMINI'
Use Gemini CLI for large codebase analysis when regular context is insufficient.

When to use it:
1. Whole-directory or multi-directory analysis.
2. Cross-file pattern audits (security, auth, error handling, caching, tests).
3. Workloads likely to exceed normal context windows (for example, more than ~100KB total).

Command patterns (validate your local Gemini CLI flags first via `gemini --help`):
- Single file: `gemini -p "@src/main.py Explain this file's purpose and structure"`
- Multiple files: `gemini -p "@package.json @src/index.js Analyze dependencies used"`
- Directory: `gemini -p "@src/ Summarize architecture and key modules"`
- Whole project (if supported by your installed version): `gemini --all_files -p "Analyze project structure and dependencies"`

Safety and verification:
- Prefer targeted `@path` scopes over full-repo scans.
- Ask Gemini to return concrete file paths/functions.
- Verify findings locally with RTK (`rtk grep`, `rtk read`) before acting.
- Do not assume undocumented Gemini flags, APIs, or behavior.
EOF_GEMINI
}

apply_gemini_large_context_section() {
    local target_path="$1"
    local allow_create_sections="$2"
    local gemini_content

    case "$USE_GEMINI_CONTEXT_MODE" in
        enable)
            if gemini_cli_available; then
                gemini_content="$(gemini_large_context_section_content)"
                if vault_mm_has_section "$target_path" "gemini-large-context"; then
                    vault_mm_upsert_section "$target_path" "gemini-large-context" "$gemini_content"
                elif [ "$allow_create_sections" -eq 1 ] || vault_mm_has_any_section "$target_path"; then
                    vault_mm_append_section_once "$target_path" "gemini-large-context" "$gemini_content"
                fi
            else
                warn_missing_gemini_cli_once
            fi
            ;;
        disable)
            if vault_mm_has_section "$target_path" "gemini-large-context"; then
                vault_mm_remove_section "$target_path" "gemini-large-context"
            fi
            ;;
        preserve)
            if vault_mm_has_section "$target_path" "gemini-large-context" && gemini_cli_available; then
                gemini_content="$(gemini_large_context_section_content)"
                vault_mm_upsert_section "$target_path" "gemini-large-context" "$gemini_content"
            fi
            ;;
    esac
}

rtk_section_content() {
    cat <<'EOF_RTK'
RTK is installed in this environment. Use RTK wrappers instead of raw commands whenever an RTK equivalent exists.

Required rewrites:
- `git ...` -> `rtk git ...`
- `gh ...` -> `rtk gh ...`
- `cargo ...` -> `rtk cargo ...`
- `cat|head|tail <file>` -> `rtk read <file>`
- `rg|grep <pattern>` -> `rtk grep <pattern>`
- `ls` -> `rtk ls`
- `vitest|jest` -> `rtk vitest run`
- `tsc` -> `rtk tsc`
- `eslint|biome` -> `rtk lint`
- `prettier` -> `rtk prettier`
- `playwright` -> `rtk playwright`
- `prisma` -> `rtk prisma`
- `ruff ...` -> `rtk ruff ...`
- `pytest` -> `rtk pytest`
- `pip ...` -> `rtk pip ...`
- `go ...` -> `rtk go ...`
- `golangci-lint` -> `rtk golangci-lint`
- `docker ...` -> `rtk docker ...`
- `kubectl ...` -> `rtk kubectl ...`
- `curl` -> `rtk curl`
- `pnpm ...` -> `rtk pnpm ...`
EOF_RTK
}

prompt_existing_file_action() {
    local target_name="$1"
    local action=""

    if [ ! -t 0 ]; then
        printf 'skip\n'
        return
    fi

    while :; do
        printf "⚠️  %s already exists. Choose: [o]verwrite / [a]ppend / [s]kip: " "$target_name" >&2
        read -r action
        case "$action" in
            o|O|overwrite|Overwrite)
                printf 'overwrite\n'
                return
                ;;
            a|A|append|Append)
                printf 'append\n'
                return
                ;;
            s|S|skip|Skip|"")
                printf 'skip\n'
                return
                ;;
            *)
                echo "Please choose one of: o, a, s" >&2
                ;;
        esac
    done
}

append_base_content() {
    local destination_path="$1"
    local base_source_path="$2"
    local append_source="$base_source_path"

    vault_mm_trim_file_end "$destination_path"

    if [ "$base_source_path" = "$destination_path" ]; then
        append_source="$(mktemp)"
        cp "$base_source_path" "$append_source"
    fi

    {
        printf '\n\n'
        cat "$append_source"
        printf '\n'
    } >> "$destination_path"

    if [ "$append_source" != "$base_source_path" ]; then
        rm -f "$append_source"
    fi
}

apply_managed_sections() {
    local target_path="$1"
    local allow_create_sections="$2"
    local skip_updates="$3"
    local docs_content workflow_content rtk_content

    if [ "$skip_updates" -eq 1 ] || [ ! -f "$target_path" ]; then
        return
    fi

    if [ "$allow_create_sections" -eq 0 ] && ! vault_mm_has_any_section "$target_path"; then
        return
    fi

    docs_content="$(docs_first_section_content)"
    if vault_mm_has_section "$target_path" "docs-first"; then
        vault_mm_upsert_section "$target_path" "docs-first" "$docs_content"
    elif [ "$allow_create_sections" -eq 1 ] || vault_mm_has_any_section "$target_path"; then
        vault_mm_append_section_once "$target_path" "docs-first" "$docs_content"
    fi

    if [ "$ENABLE_WORKFLOW_ORCHESTRATION" = "1" ]; then
        workflow_content="$(workflow_orchestration_section_content)"
        if vault_mm_has_section "$target_path" "workflow-orchestration"; then
            vault_mm_upsert_section "$target_path" "workflow-orchestration" "$workflow_content"
        elif [ "$allow_create_sections" -eq 1 ] || vault_mm_has_any_section "$target_path"; then
            vault_mm_append_section_once "$target_path" "workflow-orchestration" "$workflow_content"
        fi
    else
        if vault_mm_has_section "$target_path" "workflow-orchestration"; then
            vault_mm_remove_section "$target_path" "workflow-orchestration"
        fi
    fi

    if rtk_is_available; then
        rtk_content="$(rtk_section_content)"
        if vault_mm_has_section "$target_path" "rtk"; then
            vault_mm_upsert_section "$target_path" "rtk" "$rtk_content"
        elif [ "$allow_create_sections" -eq 1 ] || vault_mm_has_any_section "$target_path"; then
            vault_mm_append_section_once "$target_path" "rtk" "$rtk_content"
        fi
    else
        if vault_mm_has_section "$target_path" "rtk"; then
            vault_mm_remove_section "$target_path" "rtk"
        fi
    fi

    apply_gemini_large_context_section "$target_path" "$allow_create_sections"
}

write_instruction_target() {
    local destination_path="$1"
    local base_source_path="$2"
    local prompt_existing="$3"
    local force_overwrite_existing="${4:-0}"
    local allow_create_sections=0
    local skip_updates=0
    local action=""

    if [ ! -f "$destination_path" ]; then
        cp "$base_source_path" "$destination_path"
        allow_create_sections=1
    elif [ "$force_overwrite_existing" -eq 1 ] && [ "$base_source_path" != "$destination_path" ]; then
        cp "$base_source_path" "$destination_path"
        allow_create_sections=1
    elif [ "$NON_INTERACTIVE" -eq 0 ] && [ "$prompt_existing" -eq 1 ] && ! vault_mm_has_any_section "$destination_path"; then
        action="$(prompt_existing_file_action "$(basename "$destination_path")")"

        case "$action" in
            overwrite)
                if [ "$base_source_path" != "$destination_path" ]; then
                    cp "$base_source_path" "$destination_path"
                fi
                allow_create_sections=1
                ;;
            append)
                append_base_content "$destination_path" "$base_source_path"
                allow_create_sections=1
                ;;
            skip)
                skip_updates=1
                ;;
        esac
    fi

    apply_managed_sections "$destination_path" "$allow_create_sections" "$skip_updates"
}

initialize_local_ai_workspace() {
    echo ""
    echo "🛡️  Initializing local .ai workspace..."
    echo "📁 Creating local .ai directory..."
    mkdir -p "$PROJECT_ROOT/.ai/plans"
    mkdir -p "$PROJECT_ROOT/.ai/reviews"
    mkdir -p "$PROJECT_ROOT/.ai/docs"
    mkdir -p "$PROJECT_ROOT/.ai/context/archive"
    mkdir -p "$PROJECT_ROOT/.ai/prompts"
    mkdir -p "$PROJECT_ROOT/.ai/cache"
    mkdir -p "$PROJECT_ROOT/.ai/agents"
    mkdir -p "$PROJECT_ROOT/.ai/extensions"

    echo "📄 Installing base templates..."
    copy_if_missing "$TEMPLATES_DIR/session-template.md" "$PROJECT_ROOT/.ai/session-template.md"

    if [ "$FULL_CONFIG_RAN" -eq 1 ]; then
        echo "✅ Rules file already refreshed by the main configurator."
    elif [ "$FORCE_CONFIG" -eq 0 ] && [ -s "$PROJECT_ROOT/.ai/rules.md" ]; then
        echo "✅ Rules file already exists. Skipping .ai rules configuration."
    elif [ -f "$SCRIPT_DIR/../scripts/vault-ai-configurator.sh" ]; then
        (
            cd "$PROJECT_ROOT"
            bash "$SCRIPT_DIR/../scripts/vault-ai-configurator.sh" --rules-only $CONFIGURATOR_FLAGS
        )
    else
        copy_if_missing "$TEMPLATES_DIR/rules.md" "$PROJECT_ROOT/.ai/rules.md"
    fi

    echo "🤖 Installing AI agents..."
    for agent_script in "$TEMPLATES_DIR/agents/"*.sh; do
        if [ "$(basename "$agent_script")" = "user-stories.sh" ]; then
            continue
        fi
        copy_if_missing "$agent_script" "$PROJECT_ROOT/.ai/agents/$(basename "$agent_script")"
        chmod +x "$PROJECT_ROOT/.ai/agents/$(basename "$agent_script")"
    done

    ln -sf ".ai/agents/plan-creator.sh" "$PROJECT_ROOT/plan"
    echo "🔗 Symlink 'plan' created for easy access."

    echo "🤖 Setting up Claude Code integration..."
    mkdir -p "$PROJECT_ROOT/.claude"
    cp "$TEMPLATES_DIR/CLAUDE_PROJECT_RULES.md" "$PROJECT_ROOT/.claude/project-rules.md"
    echo "✅ Updated $PROJECT_ROOT/.claude/project-rules.md"

    echo ""
    echo "✨ Local .ai workspace initialized successfully!"
    echo "📍 Vault: $AI_VAULT"
    echo "🔗 Local Link: .ai/"
    echo "🤖 Claude Rules: .claude/project-rules.md"
    echo "🧩 Optional workflows: use vault-ext to enable extensions when needed."
}

echo "🛡️  Initializing AI Shadow Vault for: $PROJECT_SLUG"
echo "📍 Project Root: $PROJECT_ROOT"

# 1. Create Vault structure
mkdir -p "$PROJECT_VAULT"

write_instruction_target "$PROJECT_VAULT/AGENTS.md" "$SCRIPT_DIR/../templates/AGENTS.md" 1
write_instruction_target "$PROJECT_VAULT/copilot-instructions.md" "$SCRIPT_DIR/../templates/copilot-instructions.md" 1
write_instruction_target "$PROJECT_VAULT/.cursorrules" "$SCRIPT_DIR/../templates/.cursorrules" 1
write_instruction_target "$PROJECT_VAULT/.windsurfrules" "$SCRIPT_DIR/../templates/.windsurfrules" 1
copy_if_missing "$SCRIPT_DIR/../templates/cody-context.json" "$PROJECT_VAULT/cody-context.json"
copy_if_missing "$SCRIPT_DIR/../templates/cody-ignore" "$PROJECT_VAULT/cody-ignore"

# 2.1 Dynamic Configuration for rules, Gemini and Claude
if [ -f "$SCRIPT_DIR/../scripts/vault-ai-configurator.sh" ]; then
    if [ "$FORCE_CONFIG" -eq 1 ] || [ ! -f "$PROJECT_VAULT/GEMINI.md" ] || [ ! -f "$PROJECT_VAULT/CLAUDE.md" ]; then
        (
            cd "$PROJECT_ROOT"
            bash "$SCRIPT_DIR/../scripts/vault-ai-configurator.sh" $CONFIGURATOR_FLAGS
        )

        GENERATED_GEMINI="$(mktemp)"
        GENERATED_CLAUDE="$(mktemp)"

        if [ -f "$PROJECT_ROOT/GEMINI.md" ]; then
            cp "$PROJECT_ROOT/GEMINI.md" "$GENERATED_GEMINI"
            rm -f "$PROJECT_ROOT/GEMINI.md"
        else
            cp "$SCRIPT_DIR/../templates/GEMINI.md" "$GENERATED_GEMINI"
        fi

        if [ -f "$PROJECT_ROOT/CLAUDE.md" ]; then
            cp "$PROJECT_ROOT/CLAUDE.md" "$GENERATED_CLAUDE"
            rm -f "$PROJECT_ROOT/CLAUDE.md"
        else
            cp "$SCRIPT_DIR/../templates/CLAUDE.md" "$GENERATED_CLAUDE"
        fi

        write_instruction_target "$PROJECT_VAULT/GEMINI.md" "$GENERATED_GEMINI" 1 "$FORCE_CONFIG"
        write_instruction_target "$PROJECT_VAULT/CLAUDE.md" "$GENERATED_CLAUDE" 1 "$FORCE_CONFIG"

        rm -f "$GENERATED_GEMINI" "$GENERATED_CLAUDE"
        FULL_CONFIG_RAN=1
        CONFIGURATION_GENERATED=1
    else
        echo "✅ Existing Gemini and Claude context found. Skipping configurator."
        echo "💡 Use --force-config to re-run the interactive project configuration."
    fi

    if [ "$CONFIGURATION_GENERATED" -eq 0 ] && [ -f "$PROJECT_VAULT/GEMINI.md" ]; then
        write_instruction_target "$PROJECT_VAULT/GEMINI.md" "$PROJECT_VAULT/GEMINI.md" 1
    fi

    if [ "$CONFIGURATION_GENERATED" -eq 0 ] && [ -f "$PROJECT_VAULT/CLAUDE.md" ]; then
        write_instruction_target "$PROJECT_VAULT/CLAUDE.md" "$PROJECT_VAULT/CLAUDE.md" 1
    fi

    # Create symlinks immediately
    ln -sf "$PROJECT_VAULT/GEMINI.md" "$PROJECT_ROOT/GEMINI.md"
    ln -sf "$PROJECT_VAULT/CLAUDE.md" "$PROJECT_ROOT/CLAUDE.md"
    ln -sf "$PROJECT_VAULT/AGENTS.md" "$PROJECT_ROOT/AGENTS.md"
else
    write_instruction_target "$PROJECT_VAULT/GEMINI.md" "$SCRIPT_DIR/../templates/GEMINI.md" 1
    write_instruction_target "$PROJECT_VAULT/CLAUDE.md" "$SCRIPT_DIR/../templates/CLAUDE.md" 1
    ln -sf "$PROJECT_VAULT/GEMINI.md" "$PROJECT_ROOT/GEMINI.md"
    ln -sf "$PROJECT_VAULT/CLAUDE.md" "$PROJECT_ROOT/CLAUDE.md"
    ln -sf "$PROJECT_VAULT/AGENTS.md" "$PROJECT_ROOT/AGENTS.md"
fi

echo "✅ Vault directory created at: $PROJECT_VAULT"

# 3. Run optional post-init hooks for extensions already enabled in the project.
if [ -x "$SCRIPT_DIR/../bin/vault-ext" ]; then
    (
        cd "$PROJECT_ROOT"
        "$SCRIPT_DIR/../bin/vault-ext" run-hook post-init >/dev/null 2>&1 || true
    )
fi

# 4. Global Git Safety Net
echo "🔒 Configuring Global Git Safety Net..."
GLOBAL_IGNORE="$HOME/.gitignore_global"
touch "$GLOBAL_IGNORE"

# Added GEMINI.md to the ignore list (+ Laravel Boost and Universal AI files)
FILES_TO_IGNORE=("GEMINI.md" ".opencode-context.md" "AGENTS.md" ".opencode.json" ".mcp.json" "CLAUDE.md" "boost.json" ".ai" ".ai/" ".ai/context/agent-context.md" "copilot-instructions.md" ".cursorrules" ".windsurfrules" "cody-context.json" "cody-ignore" ".github/" ".cody/" ".claude/" ".codex/" ".cursor/" ".gemini/" ".junie/" ".opencode/" "polyscope.json" "plan")

for file in "${FILES_TO_IGNORE[@]}"; do
    if ! grep -q "$file" "$GLOBAL_IGNORE"; then
        echo "**/$file" >> "$GLOBAL_IGNORE"
    fi
done

git config --global core.excludesfile "$GLOBAL_IGNORE"

# 4.1 Local Git Safety Net (Silent Ignore)
if [ -d "$PROJECT_ROOT/.git" ]; then
    echo "🙈 Updating .git/info/exclude..."
    GIT_EXCLUDE="$PROJECT_ROOT/.git/info/exclude"
    touch "$GIT_EXCLUDE"
    for file in "${FILES_TO_IGNORE[@]}"; do
        if ! grep -q "$file" "$GIT_EXCLUDE"; then
            echo "$file" >> "$GIT_EXCLUDE"
        fi
    done
elif [ -f "$PROJECT_ROOT/.gitignore" ]; then
    echo "📝 Updating local .gitignore..."
    for file in "${FILES_TO_IGNORE[@]}"; do
        if ! grep -q "$file" "$PROJECT_ROOT/.gitignore"; then
            echo "$file" >> "$PROJECT_ROOT/.gitignore"
        fi
    done
fi

echo "✅ Git Safety Net updated (Global + Local Exclude)."

initialize_local_ai_workspace
