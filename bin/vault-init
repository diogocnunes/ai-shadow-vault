#!/bin/bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../scripts/lib/vault-resolver.sh"
source "$SCRIPT_DIR/../scripts/lib/extensions-resolver.sh"

# Defaults: safe, minimal, non-invasive.
NON_INTERACTIVE=1
FORCE_HERD=0
FORCE_CONFIG=0
OPTIMIZE_MODE=0
INTERACTIVE_MODE=0
ASSUME_YES=0
DRY_RUN=0

# Compatibility flags
USE_GEMINI_CONTEXT_MODE="preserve"
ENABLE_WORKFLOW_ORCHESTRATION="${AI_SHADOW_ENABLE_WORKFLOW_ORCHESTRATION:-0}"

while [[ "$#" -gt 0 ]]; do
    case "${1:-}" in
        --non-interactive)
            NON_INTERACTIVE=1
            ;;
        --interactive)
            INTERACTIVE_MODE=1
            NON_INTERACTIVE=0
            ;;
        --yes)
            ASSUME_YES=1
            ;;
        --optimize)
            OPTIMIZE_MODE=1
            ;;
        --dry-run)
            DRY_RUN=1
            ;;
        --force-config)
            FORCE_CONFIG=1
            OPTIMIZE_MODE=1
            INTERACTIVE_MODE=1
            NON_INTERACTIVE=0
            ;;
        --herd)
            FORCE_HERD=1
            ;;
        --enable-workflow)
            ENABLE_WORKFLOW_ORCHESTRATION=1
            ;;
        --disable-workflow)
            ENABLE_WORKFLOW_ORCHESTRATION=0
            ;;
        --use-gemini)
            USE_GEMINI_CONTEXT_MODE="enable"
            ;;
        --no-use-gemini)
            USE_GEMINI_CONTEXT_MODE="disable"
            ;;
        *)
            echo "Unknown option: $1" >&2
            exit 1
            ;;
    esac
    shift
done

if [[ "$FORCE_CONFIG" -eq 1 ]]; then
    echo "ℹ️  --force-config is deprecated. Using: vault-init --optimize --interactive"
fi

if [[ "$USE_GEMINI_CONTEXT_MODE" != "preserve" ]]; then
    echo "ℹ️  --use-gemini/--no-use-gemini are compatibility flags only. Optional tool behavior is controlled by .ai/rules.md."
fi

if [[ "$ENABLE_WORKFLOW_ORCHESTRATION" != "0" ]]; then
    echo "ℹ️  workflow orchestration section injection is deprecated in adapter files."
fi

if [[ "$DRY_RUN" -eq 1 && "$OPTIMIZE_MODE" -eq 0 ]]; then
    echo "ℹ️  --dry-run is only meaningful with --optimize. Continuing with safe default init."
fi

CONFIGURATOR_FLAGS=()
if [[ "$FORCE_HERD" -eq 1 ]]; then
    CONFIGURATOR_FLAGS+=(--herd)
fi
if [[ "$NON_INTERACTIVE" -eq 1 ]]; then
    CONFIGURATOR_FLAGS+=(--non-interactive)
fi

PROJECT_ROOT="$(vault_resolve_project_root "$PWD")"
PROJECT_SLUG="$(vault_resolve_project_slug "$PROJECT_ROOT")"
PROJECT_VAULT="$(vault_resolve_project_vault "$PROJECT_ROOT")"
TEMPLATES_DIR="$SCRIPT_DIR/../templates"

MANAGED_MARKER="<!-- AI-SHADOW-VAULT: MANAGED FILE -->"
OPTIMIZE_PLAN_FILES=()
OPTIMIZE_PLAN_SKILLS_AUTO=()
OPTIMIZE_PLAN_SKILLS_SUGGEST=()
OPTIMIZE_PLAN_CONTEXT=()
OPTIMIZE_PLAN_MISC=()
OPTIMIZE_APPLIED=0

file_is_managed() {
    local path="$1"
    [[ -f "$path" ]] || return 1
    grep -q '^<!-- AI-SHADOW-VAULT: MANAGED FILE -->' "$path"
}

copy_managed_template() {
    local source_path="$1"
    local destination_path="$2"
    local force_overwrite="${3:-0}"

    mkdir -p "$(dirname "$destination_path")"

    if [[ ! -e "$destination_path" ]]; then
        cp "$source_path" "$destination_path"
        return
    fi

    if [[ "$force_overwrite" -eq 1 ]] || file_is_managed "$destination_path"; then
        cp "$source_path" "$destination_path"
        return
    fi

    echo "⚠️  Preserving user-authored file: $destination_path"
}

ensure_link() {
    local source="$1"
    local target="$2"
    ln -sf "$source" "$target"
}

migrate_archive_layout() {
    local local_ai="$1"
    local legacy_archive="$local_ai/context/archive"
    local modern_archive="$local_ai/archive"

    mkdir -p "$modern_archive"

    if [[ -d "$legacy_archive" ]]; then
        while IFS= read -r -d '' legacy_file; do
            rel_path="${legacy_file#$legacy_archive/}"
            target_path="$modern_archive/$rel_path"
            mkdir -p "$(dirname "$target_path")"
            [[ -e "$target_path" ]] || mv "$legacy_file" "$target_path"
        done < <(find "$legacy_archive" -type f -print0)
    fi
}

write_capabilities_file() {
    local project_root="$1"
    local cap_file="$project_root/.ai/context/capabilities.json"

    mkdir -p "$(dirname "$cap_file")"

    local has_rtk=0
    local has_gemini=0
    local has_context7=0

    command -v rtk >/dev/null 2>&1 && has_rtk=1
    command -v gemini >/dev/null 2>&1 && has_gemini=1
    command -v context7 >/dev/null 2>&1 && has_context7=1

    cat > "$cap_file" <<EOF_CAP
{
  "generated_by": "vault-init",
  "generated_at": "$(date -u +"%Y-%m-%dT%H:%M:%SZ")",
  "capabilities": {
    "rtk": { "available": $has_rtk, "required": false },
    "gemini_cli": { "available": $has_gemini, "required": false },
    "context7": { "available": $has_context7, "required": false }
  },
  "fallback_policy": "Missing optional tools must not block vault operation."
}
EOF_CAP
}

install_optional_new_task_commands() {
    local project_root="$1"
    local source_prompt="$project_root/.ai/prompts/new-task.md"

    [[ -f "$source_prompt" ]] || return 0

    mkdir -p "$project_root/.claude/commands"
    copy_managed_template "$source_prompt" "$project_root/.claude/commands/new-task.md" 1

    local target_dir
    for target_dir in \
        "$project_root/.gemini/commands" \
        "$project_root/.codex/commands" \
        "$project_root/.opencode/commands"; do
        if [[ -d "$(dirname "$target_dir")" ]]; then
            mkdir -p "$target_dir"
            copy_managed_template "$source_prompt" "$target_dir/new-task.md" 1
        fi
    done
}

initialize_vault_adapters() {
    mkdir -p "$PROJECT_VAULT"

    copy_managed_template "$TEMPLATES_DIR/AGENTS.md" "$PROJECT_VAULT/AGENTS.md" "$FORCE_CONFIG"
    copy_managed_template "$TEMPLATES_DIR/CLAUDE.md" "$PROJECT_VAULT/CLAUDE.md" "$FORCE_CONFIG"
    copy_managed_template "$TEMPLATES_DIR/GEMINI.md" "$PROJECT_VAULT/GEMINI.md" "$FORCE_CONFIG"
    copy_managed_template "$TEMPLATES_DIR/.cursorrules" "$PROJECT_VAULT/.cursorrules" "$FORCE_CONFIG"
    copy_managed_template "$TEMPLATES_DIR/.windsurfrules" "$PROJECT_VAULT/.windsurfrules" "$FORCE_CONFIG"
    copy_managed_template "$TEMPLATES_DIR/copilot-instructions.md" "$PROJECT_VAULT/copilot-instructions.md" "$FORCE_CONFIG"

    [[ -f "$PROJECT_VAULT/cody-context.json" ]] || cp "$TEMPLATES_DIR/cody-context.json" "$PROJECT_VAULT/cody-context.json"
    [[ -f "$PROJECT_VAULT/cody-ignore" ]] || cp "$TEMPLATES_DIR/cody-ignore" "$PROJECT_VAULT/cody-ignore"

    ensure_link "$PROJECT_VAULT/AGENTS.md" "$PROJECT_ROOT/AGENTS.md"
    ensure_link "$PROJECT_VAULT/CLAUDE.md" "$PROJECT_ROOT/CLAUDE.md"
    ensure_link "$PROJECT_VAULT/GEMINI.md" "$PROJECT_ROOT/GEMINI.md"
    ensure_link "$PROJECT_VAULT/.cursorrules" "$PROJECT_ROOT/.cursorrules"
    ensure_link "$PROJECT_VAULT/.windsurfrules" "$PROJECT_ROOT/.windsurfrules"

    echo "✅ Vault adapters initialized at: $PROJECT_VAULT"
}

run_configurator() {
    if [[ ! -x "$SCRIPT_DIR/../scripts/vault-ai-configurator.sh" ]]; then
        copy_managed_template "$TEMPLATES_DIR/.ai/rules.md" "$PROJECT_ROOT/.ai/rules.md" 1
        copy_managed_template "$TEMPLATES_DIR/.ai/context/project-context.md" "$PROJECT_ROOT/.ai/context/project-context.md" 1
        return
    fi

    (
        cd "$PROJECT_ROOT"
        if [[ -n "${CONFIGURATOR_FLAGS[*]-}" ]]; then
            bash "$SCRIPT_DIR/../scripts/vault-ai-configurator.sh" "${CONFIGURATOR_FLAGS[@]}"
        else
            bash "$SCRIPT_DIR/../scripts/vault-ai-configurator.sh"
        fi
    )
}

prompt_yes_no() {
    local prompt="$1"
    local default_yes="$2"
    local answer=""

    if [[ "$ASSUME_YES" -eq 1 || "$NON_INTERACTIVE" -eq 1 ]]; then
        [[ "$default_yes" -eq 1 ]] && return 0 || return 1
    fi

    if [[ "$default_yes" -eq 1 ]]; then
        read -r -p "$prompt [Y/n]: " answer
        [[ -z "$answer" || "$answer" =~ ^([yY][eE][sS]|[yY])$ ]]
    else
        read -r -p "$prompt [y/N]: " answer
        [[ "$answer" =~ ^([yY][eE][sS]|[yY])$ ]]
    fi
}

opt_plan_add_unique() {
    local array_name="$1"
    local item="$2"
    local existing

    case "$array_name" in
        OPTIMIZE_PLAN_FILES)
            for existing in "${OPTIMIZE_PLAN_FILES[@]:-}"; do
                [[ "$existing" == "$item" ]] && return 0
            done
            OPTIMIZE_PLAN_FILES+=("$item")
            ;;
        OPTIMIZE_PLAN_SKILLS_AUTO)
            for existing in "${OPTIMIZE_PLAN_SKILLS_AUTO[@]:-}"; do
                [[ "$existing" == "$item" ]] && return 0
            done
            OPTIMIZE_PLAN_SKILLS_AUTO+=("$item")
            ;;
        OPTIMIZE_PLAN_SKILLS_SUGGEST)
            for existing in "${OPTIMIZE_PLAN_SKILLS_SUGGEST[@]:-}"; do
                [[ "$existing" == "$item" ]] && return 0
            done
            OPTIMIZE_PLAN_SKILLS_SUGGEST+=("$item")
            ;;
        OPTIMIZE_PLAN_CONTEXT)
            for existing in "${OPTIMIZE_PLAN_CONTEXT[@]:-}"; do
                [[ "$existing" == "$item" ]] && return 0
            done
            OPTIMIZE_PLAN_CONTEXT+=("$item")
            ;;
        OPTIMIZE_PLAN_MISC)
            for existing in "${OPTIMIZE_PLAN_MISC[@]:-}"; do
                [[ "$existing" == "$item" ]] && return 0
            done
            OPTIMIZE_PLAN_MISC+=("$item")
            ;;
    esac
}

would_rewrite_file() {
    local destination_path="$1"
    local force_overwrite="${2:-0}"

    if [[ ! -e "$destination_path" ]]; then
        return 0
    fi

    if [[ "$force_overwrite" -eq 1 ]]; then
        return 0
    fi

    if file_is_managed "$destination_path"; then
        return 0
    fi

    return 1
}

collect_optimize_skill_decisions() {
    OPTIMIZE_PLAN_SKILLS_AUTO=()
    OPTIMIZE_PLAN_SKILLS_SUGGEST=()

    if [[ ! -x "$SCRIPT_DIR/../bin/vault-skills" ]]; then
        return
    fi

    local line decision skill confidence formatted
    while IFS= read -r line; do
        [[ -n "$line" ]] || continue
        IFS='|' read -r decision skill confidence <<< "$line"
        [[ -n "$decision" && -n "$skill" && -n "$confidence" ]] || continue

        if [[ "$decision" == "auto" ]]; then
            formatted="$skill (confidence: $confidence, auto-enabled)"
            opt_plan_add_unique OPTIMIZE_PLAN_SKILLS_AUTO "$formatted"
        elif [[ "$decision" == "suggest" ]]; then
            formatted="$skill (confidence: $confidence, suggested only)"
            opt_plan_add_unique OPTIMIZE_PLAN_SKILLS_SUGGEST "$formatted"
        fi
    done < <(VAULT_SKILLS_NO_WRITE=1 "$SCRIPT_DIR/../bin/vault-skills" suggest --plan 2>/dev/null || true)
}

collect_optimize_plan() {
    local local_ai="$PROJECT_ROOT/.ai"
    local legacy_archive="$local_ai/context/archive"
    local modern_archive="$local_ai/archive"

    OPTIMIZE_PLAN_FILES=()
    OPTIMIZE_PLAN_CONTEXT=()
    OPTIMIZE_PLAN_MISC=()
    OPTIMIZE_PLAN_SKILLS_AUTO=()
    OPTIMIZE_PLAN_SKILLS_SUGGEST=()

    local adapter_targets=(
        "$PROJECT_VAULT/AGENTS.md|$FORCE_CONFIG"
        "$PROJECT_VAULT/CLAUDE.md|$FORCE_CONFIG"
        "$PROJECT_VAULT/GEMINI.md|$FORCE_CONFIG"
        "$PROJECT_VAULT/.cursorrules|$FORCE_CONFIG"
        "$PROJECT_VAULT/.windsurfrules|$FORCE_CONFIG"
        "$PROJECT_VAULT/copilot-instructions.md|$FORCE_CONFIG"
        "$local_ai/session-template.md|$FORCE_CONFIG"
        "$local_ai/context/current-task.template.md|$FORCE_CONFIG"
        "$local_ai/context/current-task.md|$FORCE_CONFIG"
        "$local_ai/context/agent-context.md|$FORCE_CONFIG"
        "$local_ai/bootstrap.md|$FORCE_CONFIG"
        "$local_ai/docs/vault-rules.md|$FORCE_CONFIG"
        "$local_ai/prompts/new-task.md|$FORCE_CONFIG"
        "$local_ai/rules.md|1"
        "$local_ai/context/project-context.md|1"
    )

    local spec destination force_value
    for spec in "${adapter_targets[@]}"; do
        IFS='|' read -r destination force_value <<< "$spec"
        if would_rewrite_file "$destination" "$force_value"; then
            opt_plan_add_unique OPTIMIZE_PLAN_FILES "$destination"
        fi
    done

    if [[ -d "$legacy_archive" ]] && find "$legacy_archive" -type f -print -quit | grep -q .; then
        opt_plan_add_unique OPTIMIZE_PLAN_MISC "Migrate legacy archive files to .ai/archive"
    fi

    opt_plan_add_unique OPTIMIZE_PLAN_CONTEXT "Refresh .ai/context/agent-context.md"
    opt_plan_add_unique OPTIMIZE_PLAN_CONTEXT "Run vault-doctor --fix guardrails pass"

    collect_optimize_skill_decisions

    if [[ -f "$PROJECT_ROOT/composer.json" ]]; then
        if grep -q '"laravel/framework"\|"filament/filament"\|"laravel/nova"\|"livewire/livewire"' "$PROJECT_ROOT/composer.json"; then
            opt_plan_add_unique OPTIMIZE_PLAN_MISC "ASV-SUGGEST-PACK-001: Laravel stack detected. Recommended: vault-ext enable laravel"
        fi
    fi
}

print_optimize_plan() {
    local files_count="${#OPTIMIZE_PLAN_FILES[@]}"
    local auto_skills_count="${#OPTIMIZE_PLAN_SKILLS_AUTO[@]}"
    local suggest_skills_count="${#OPTIMIZE_PLAN_SKILLS_SUGGEST[@]}"
    local context_count="${#OPTIMIZE_PLAN_CONTEXT[@]}"
    local misc_count="${#OPTIMIZE_PLAN_MISC[@]}"
    local item

    echo ""
    echo "Optimization plan:"
    echo ""
    echo "- Rewrite $files_count managed files"
    if (( files_count > 0 )); then
        for item in "${OPTIMIZE_PLAN_FILES[@]:0:6}"; do
            echo "  - $item"
        done
        if (( files_count > 6 )); then
            echo "  - ... and $((files_count - 6)) more"
        fi
    fi

    echo "- Skills decisions:"
    if (( auto_skills_count > 0 )); then
        for item in "${OPTIMIZE_PLAN_SKILLS_AUTO[@]}"; do
            echo "  - $item"
        done
    fi
    if (( suggest_skills_count > 0 )); then
        for item in "${OPTIMIZE_PLAN_SKILLS_SUGGEST[@]}"; do
            echo "  - $item"
        done
    fi
    if (( auto_skills_count == 0 && suggest_skills_count == 0 )); then
        echo "  - none"
    fi
    echo "  - auto threshold: >= 0.80"
    echo "  - suggested threshold: >= 0.50 and < 0.80"

    echo "- Apply $context_count context optimizations"
    if (( context_count > 0 )); then
        for item in "${OPTIMIZE_PLAN_CONTEXT[@]}"; do
            echo "  - $item"
        done
    fi

    if (( misc_count > 0 )); then
        echo "- Apply $misc_count migration actions"
        for item in "${OPTIMIZE_PLAN_MISC[@]}"; do
            echo "  - $item"
        done
    fi
}

confirm_optimize_plan() {
    if [[ "$DRY_RUN" -eq 1 ]]; then
        echo ""
        echo "Dry-run mode enabled. No changes applied."
        return 1
    fi

    if prompt_yes_no "Apply optimization plan?" 1; then
        return 0
    fi

    echo "Optimization canceled by user."
    return 1
}

print_optimize_next_steps() {
    echo ""
    echo "Next steps:"
    echo "- vault-task new"
    echo "- vault-doctor"
    echo "- vault-test"
}

initialize_local_ai_workspace() {
    local local_ai="$PROJECT_ROOT/.ai"

    echo ""
    echo "🛡️  Initializing local .ai workspace..."

    mkdir -p "$local_ai/plans" "$local_ai/reviews" "$local_ai/docs" "$local_ai/context" "$local_ai/prompts" "$local_ai/cache" "$local_ai/agents" "$local_ai/extensions" "$local_ai/skills" "$local_ai/archive"

    migrate_archive_layout "$local_ai"

    copy_managed_template "$TEMPLATES_DIR/session-template.md" "$local_ai/session-template.md" "$FORCE_CONFIG"
    copy_managed_template "$TEMPLATES_DIR/.ai/context/current-task.md" "$local_ai/context/current-task.template.md" "$FORCE_CONFIG"
    copy_managed_template "$TEMPLATES_DIR/.ai/context/current-task.md" "$local_ai/context/current-task.md" "$FORCE_CONFIG"
    copy_managed_template "$TEMPLATES_DIR/.ai/context/agent-context.md" "$local_ai/context/agent-context.md" "$FORCE_CONFIG"
    copy_managed_template "$TEMPLATES_DIR/.ai/bootstrap.md" "$local_ai/bootstrap.md" "$FORCE_CONFIG"
    copy_managed_template "$TEMPLATES_DIR/.ai/docs/vault-rules.md" "$local_ai/docs/vault-rules.md" "$FORCE_CONFIG"
    copy_managed_template "$TEMPLATES_DIR/.ai/prompts/new-task.md" "$local_ai/prompts/new-task.md" "$FORCE_CONFIG"

    if [[ "$FORCE_CONFIG" -eq 1 || ! -f "$local_ai/rules.md" || ! -f "$local_ai/context/project-context.md" || "$OPTIMIZE_MODE" -eq 1 ]]; then
        run_configurator
    else
        echo "✅ Existing rules and project-context detected. Skipping configurator."
    fi

    write_capabilities_file "$PROJECT_ROOT"

    echo "🤖 Installing local helper agents..."
    local agent_script
    for agent_script in "$TEMPLATES_DIR/agents/"*.sh; do
        if [[ "$(basename "$agent_script")" == "user-stories.sh" ]]; then
            continue
        fi
        copy_managed_template "$agent_script" "$local_ai/agents/$(basename "$agent_script")" "$FORCE_CONFIG"
        chmod +x "$local_ai/agents/$(basename "$agent_script")"
    done

    ln -sf ".ai/agents/plan-creator.sh" "$PROJECT_ROOT/plan"

    mkdir -p "$PROJECT_ROOT/.claude"
    copy_managed_template "$TEMPLATES_DIR/CLAUDE_PROJECT_RULES.md" "$PROJECT_ROOT/.claude/project-rules.md" 1

    install_optional_new_task_commands "$PROJECT_ROOT"

    if [[ -x "$SCRIPT_DIR/../scripts/build-active-skills.sh" ]]; then
        "$SCRIPT_DIR/../scripts/build-active-skills.sh" "$PROJECT_ROOT" >/dev/null || true
    fi

    if [[ -x "$SCRIPT_DIR/../scripts/vault-ai-context-file.sh" ]]; then
        "$SCRIPT_DIR/../scripts/vault-ai-context-file.sh" >/dev/null || true
    fi

    if [[ "$OPTIMIZE_MODE" -eq 1 ]]; then
        echo ""
        echo "⚙️  Optimize mode: detect → confirm → refine"

        if [[ -x "$SCRIPT_DIR/../bin/vault-skills" ]]; then
            "$SCRIPT_DIR/../bin/vault-skills" auto || true
            "$SCRIPT_DIR/../bin/vault-skills" suggest >/dev/null 2>&1 || true
        fi

        if [[ -x "$SCRIPT_DIR/../bin/vault-doctor" ]]; then
            "$SCRIPT_DIR/../bin/vault-doctor" --fix || true
        fi
    fi

    echo "✨ Local .ai workspace initialized successfully."
}

configure_git_safety_net() {
    if [[ "${AI_SHADOW_SKIP_GIT_SAFETY:-0}" == "1" ]]; then
        echo "ℹ️  Skipping Git Safety Net update (AI_SHADOW_SKIP_GIT_SAFETY=1)."
        return
    fi

    echo "🔒 Configuring Global Git Safety Net..."

    GLOBAL_IGNORE="$HOME/.gitignore_global"
    touch "$GLOBAL_IGNORE"

    FILES_TO_IGNORE=(
        "GEMINI.md" ".opencode-context.md" "AGENTS.md" ".opencode.json" ".mcp.json" "CLAUDE.md"
        "boost.json" ".ai" ".ai/" ".ai/context/agent-context.md" ".ai/context/current-task.md"
        ".ai/context/current-task.template.md" ".ai/archive/" "copilot-instructions.md" ".cursorrules"
        ".windsurfrules" "cody-context.json" "cody-ignore" ".github/" ".cody/" ".claude/" ".codex/"
        ".cursor/" ".gemini/" ".junie/" ".opencode/" "polyscope.json" "plan"
    )

    local file
    for file in "${FILES_TO_IGNORE[@]}"; do
        if ! grep -q "$file" "$GLOBAL_IGNORE"; then
            echo "**/$file" >> "$GLOBAL_IGNORE"
        fi
    done

    git config --global core.excludesfile "$GLOBAL_IGNORE"

    if [[ -d "$PROJECT_ROOT/.git" ]]; then
        echo "🙈 Updating .git/info/exclude..."
        GIT_EXCLUDE="$PROJECT_ROOT/.git/info/exclude"
        touch "$GIT_EXCLUDE"

        for file in "${FILES_TO_IGNORE[@]}"; do
            if ! grep -q "$file" "$GIT_EXCLUDE"; then
                echo "$file" >> "$GIT_EXCLUDE"
            fi
        done
    elif [[ -f "$PROJECT_ROOT/.gitignore" ]]; then
        echo "📝 Updating local .gitignore..."
        for file in "${FILES_TO_IGNORE[@]}"; do
            if ! grep -q "$file" "$PROJECT_ROOT/.gitignore"; then
                echo "$file" >> "$PROJECT_ROOT/.gitignore"
            fi
        done
    fi

    echo "✅ Git Safety Net updated (Global + Local Exclude)."
}

echo "🛡️  Initializing AI Shadow Vault for: $PROJECT_SLUG"
echo "📍 Project Root: $PROJECT_ROOT"

if [[ "$OPTIMIZE_MODE" -eq 1 ]]; then
    echo "Mode: optimize"
else
    echo "Mode: safe default"
fi

if [[ "$OPTIMIZE_MODE" -eq 1 ]]; then
    collect_optimize_plan
    print_optimize_plan
    if ! confirm_optimize_plan; then
        exit 0
    fi
    OPTIMIZE_APPLIED=1
fi

initialize_vault_adapters
initialize_local_ai_workspace
configure_git_safety_net

if [[ -x "$SCRIPT_DIR/../bin/vault-ext" ]]; then
    (
        cd "$PROJECT_ROOT"
        "$SCRIPT_DIR/../bin/vault-ext" run-hook post-init >/dev/null 2>&1 || true
    )
fi

echo "✅ Initialization completed."

if [[ "$OPTIMIZE_MODE" -eq 1 && "$OPTIMIZE_APPLIED" -eq 1 ]]; then
    print_optimize_next_steps
fi
