#!/bin/bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../scripts/lib/vault-resolver.sh"
source "$SCRIPT_DIR/../scripts/lib/extensions-resolver.sh"

NON_INTERACTIVE=0
FORCE_CONFIG=0
FORCE_HERD=0
FULL_CONFIG_RAN=0

while [[ "$#" -gt 0 ]]; do
    case "${1:-}" in
        --non-interactive)
            NON_INTERACTIVE=1
            ;;
        --force-config)
            FORCE_CONFIG=1
            ;;
        --herd)
            FORCE_HERD=1
            NON_INTERACTIVE=1
            ;;
        *)
            echo "Unknown option: $1" >&2
            exit 1
            ;;
    esac
    shift
done

# Build configurator flags once, used in all calls below
if [[ "$FORCE_HERD" -eq 1 ]]; then
    CONFIGURATOR_FLAGS="--herd"
elif [[ "$NON_INTERACTIVE" -eq 1 ]]; then
    CONFIGURATOR_FLAGS="--non-interactive"
else
    CONFIGURATOR_FLAGS=""
fi

DATA_ROOT="$(vault_ensure_data_root)"
PROJECT_ROOT="$(vault_resolve_project_root "$PWD")"
PROJECT_SLUG="$(vault_resolve_project_slug "$PROJECT_ROOT")"
PROJECT_VAULT="$(vault_resolve_project_vault "$PROJECT_ROOT")"
AI_VAULT="$PROJECT_VAULT/.ai"
TEMPLATES_DIR="$SCRIPT_DIR/../templates"

copy_if_missing() {
    local source_path="$1"
    local destination_path="$2"

    if [ ! -e "$destination_path" ]; then
        cp "$source_path" "$destination_path"
    fi
}

initialize_local_ai_workspace() {
    echo ""
    echo "🛡️  Initializing local .ai workspace..."
    echo "📁 Creating local .ai directory..."
    mkdir -p "$PROJECT_ROOT/.ai/plans"
    mkdir -p "$PROJECT_ROOT/.ai/reviews"
    mkdir -p "$PROJECT_ROOT/.ai/docs"
    mkdir -p "$PROJECT_ROOT/.ai/context/archive"
    mkdir -p "$PROJECT_ROOT/.ai/prompts"
    mkdir -p "$PROJECT_ROOT/.ai/cache"
    mkdir -p "$PROJECT_ROOT/.ai/agents"
    mkdir -p "$PROJECT_ROOT/.ai/extensions"

    echo "📄 Installing base templates..."
    copy_if_missing "$TEMPLATES_DIR/session-template.md" "$PROJECT_ROOT/.ai/session-template.md"

    if [ "$FULL_CONFIG_RAN" -eq 1 ]; then
        echo "✅ Rules file already refreshed by the main configurator."
    elif [ "$FORCE_CONFIG" -eq 0 ] && [ -s "$PROJECT_ROOT/.ai/rules.md" ]; then
        echo "✅ Rules file already exists. Skipping .ai rules configuration."
    elif [ -f "$SCRIPT_DIR/../scripts/vault-ai-configurator.sh" ]; then
        (
            cd "$PROJECT_ROOT"
            bash "$SCRIPT_DIR/../scripts/vault-ai-configurator.sh" --rules-only $CONFIGURATOR_FLAGS
        )
    else
        copy_if_missing "$TEMPLATES_DIR/rules.md" "$PROJECT_ROOT/.ai/rules.md"
    fi

    echo "🤖 Installing AI agents..."
    for agent_script in "$TEMPLATES_DIR/agents/"*.sh; do
        if [ "$(basename "$agent_script")" = "user-stories.sh" ]; then
            continue
        fi
        copy_if_missing "$agent_script" "$PROJECT_ROOT/.ai/agents/$(basename "$agent_script")"
        chmod +x "$PROJECT_ROOT/.ai/agents/$(basename "$agent_script")"
    done

    ln -sf ".ai/agents/plan-creator.sh" "$PROJECT_ROOT/plan"
    echo "🔗 Symlink 'plan' created for easy access."

    echo "🤖 Setting up Claude Code integration..."
    mkdir -p "$PROJECT_ROOT/.claude"
    cp "$TEMPLATES_DIR/CLAUDE_PROJECT_RULES.md" "$PROJECT_ROOT/.claude/project-rules.md"
    echo "✅ Updated $PROJECT_ROOT/.claude/project-rules.md"

    echo ""
    echo "✨ Local .ai workspace initialized successfully!"
    echo "📍 Vault: $AI_VAULT"
    echo "🔗 Local Link: .ai/"
    echo "🤖 Claude Rules: .claude/project-rules.md"
    echo "🧩 Optional workflows: use vault-ext to enable extensions when needed."
}

echo "🛡️  Initializing AI Shadow Vault for: $PROJECT_SLUG"
echo "📍 Project Root: $PROJECT_ROOT"

# 1. Create Vault structure
mkdir -p "$PROJECT_VAULT"

copy_if_missing "$SCRIPT_DIR/../templates/AGENTS.md" "$PROJECT_VAULT/AGENTS.md"
copy_if_missing "$SCRIPT_DIR/../templates/copilot-instructions.md" "$PROJECT_VAULT/copilot-instructions.md"
copy_if_missing "$SCRIPT_DIR/../templates/.cursorrules" "$PROJECT_VAULT/.cursorrules"
copy_if_missing "$SCRIPT_DIR/../templates/.windsurfrules" "$PROJECT_VAULT/.windsurfrules"
copy_if_missing "$SCRIPT_DIR/../templates/cody-context.json" "$PROJECT_VAULT/cody-context.json"
copy_if_missing "$SCRIPT_DIR/../templates/cody-ignore" "$PROJECT_VAULT/cody-ignore"

# 2.1 Dynamic Configuration for rules, Gemini and Claude
if [ -f "$SCRIPT_DIR/../scripts/vault-ai-configurator.sh" ]; then
    if [ "$FORCE_CONFIG" -eq 1 ] || [ ! -f "$PROJECT_VAULT/GEMINI.md" ] || [ ! -f "$PROJECT_VAULT/CLAUDE.md" ]; then
        (
            cd "$PROJECT_ROOT"
            bash "$SCRIPT_DIR/../scripts/vault-ai-configurator.sh" $CONFIGURATOR_FLAGS
        )
        [ -f "$PROJECT_ROOT/GEMINI.md" ] && mv -f "$PROJECT_ROOT/GEMINI.md" "$PROJECT_VAULT/GEMINI.md"
        [ -f "$PROJECT_ROOT/CLAUDE.md" ] && mv -f "$PROJECT_ROOT/CLAUDE.md" "$PROJECT_VAULT/CLAUDE.md"
        FULL_CONFIG_RAN=1
    else
        echo "✅ Existing Gemini and Claude context found. Skipping configurator."
        echo "💡 Use --force-config to re-run the interactive project configuration."
    fi

    # Create symlinks immediately
    ln -sf "$PROJECT_VAULT/GEMINI.md" "$PROJECT_ROOT/GEMINI.md"
    ln -sf "$PROJECT_VAULT/CLAUDE.md" "$PROJECT_ROOT/CLAUDE.md"
    ln -sf "$PROJECT_VAULT/AGENTS.md" "$PROJECT_ROOT/AGENTS.md"
else
    copy_if_missing "$SCRIPT_DIR/../templates/GEMINI.md" "$PROJECT_VAULT/GEMINI.md"
    copy_if_missing "$SCRIPT_DIR/../templates/CLAUDE.md" "$PROJECT_VAULT/CLAUDE.md"
    ln -sf "$PROJECT_VAULT/GEMINI.md" "$PROJECT_ROOT/GEMINI.md"
    ln -sf "$PROJECT_VAULT/CLAUDE.md" "$PROJECT_ROOT/CLAUDE.md"
    ln -sf "$PROJECT_VAULT/AGENTS.md" "$PROJECT_ROOT/AGENTS.md"
fi

echo "✅ Vault directory created at: $PROJECT_VAULT"

# 3. Run optional post-init hooks for extensions already enabled in the project.
if [ -x "$SCRIPT_DIR/../bin/vault-ext" ]; then
    (
        cd "$PROJECT_ROOT"
        "$SCRIPT_DIR/../bin/vault-ext" run-hook post-init >/dev/null 2>&1 || true
    )
fi

# 4. Global Git Safety Net
echo "🔒 Configuring Global Git Safety Net..."
GLOBAL_IGNORE="$HOME/.gitignore_global"
touch "$GLOBAL_IGNORE"

# Added GEMINI.md to the ignore list (+ Laravel Boost and Universal AI files)
FILES_TO_IGNORE=("GEMINI.md" ".opencode-context.md" "AGENTS.md" ".opencode.json" ".mcp.json" "CLAUDE.md" "boost.json" ".ai" ".ai/" ".ai/context/agent-context.md" "copilot-instructions.md" ".cursorrules" ".windsurfrules" "cody-context.json" "cody-ignore" ".github/" ".cody/" ".claude/" ".codex/" ".cursor/" ".gemini/" ".junie/" ".opencode/" "polyscope.json" "plan")

for file in "${FILES_TO_IGNORE[@]}"; do
    if ! grep -q "$file" "$GLOBAL_IGNORE"; then
        echo "**/$file" >> "$GLOBAL_IGNORE"
    fi
done

git config --global core.excludesfile "$GLOBAL_IGNORE"

# 4.1 Local Git Safety Net (Silent Ignore)
if [ -d "$PROJECT_ROOT/.git" ]; then
    echo "🙈 Updating .git/info/exclude..."
    GIT_EXCLUDE="$PROJECT_ROOT/.git/info/exclude"
    touch "$GIT_EXCLUDE"
    for file in "${FILES_TO_IGNORE[@]}"; do
        if ! grep -q "$file" "$GIT_EXCLUDE"; then
            echo "$file" >> "$GIT_EXCLUDE"
        fi
    done
elif [ -f "$PROJECT_ROOT/.gitignore" ]; then
    echo "📝 Updating local .gitignore..."
    for file in "${FILES_TO_IGNORE[@]}"; do
        if ! grep -q "$file" "$PROJECT_ROOT/.gitignore"; then
            echo "$file" >> "$PROJECT_ROOT/.gitignore"
        fi
    done
fi

echo "✅ Git Safety Net updated (Global + Local Exclude)."



initialize_local_ai_workspace
