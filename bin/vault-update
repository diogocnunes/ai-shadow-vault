#!/bin/bash

set -euo pipefail

GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m'

INSTALL_PATH="$HOME/.ai-shadow-vault"
CALLER_DIR="$PWD"

log_info() {
    echo -e "${BLUE}$1${NC}"
}

log_success() {
    echo -e "${GREEN}$1${NC}"
}

log_warn() {
    echo -e "${YELLOW}$1${NC}"
}

project_context_available() {
    local candidate="$1"

    [ -d "$candidate" ] || return 1
    [ "$candidate" != "$INSTALL_PATH" ] || return 1

    if git -C "$candidate" rev-parse --show-toplevel >/dev/null 2>&1; then
        return 0
    fi

    [ -d "$candidate/.ai" ] && return 0
    [ -d "$candidate/.git" ] && return 0
    [ -f "$candidate/composer.json" ] && return 0
    [ -f "$candidate/package.json" ] && return 0

    return 1
}

run_post_update() {
    local project_dir="$1"

    log_info "🧹 Running post-update project refresh..."

    (
        cd "$project_dir"
        "$INSTALL_PATH/bin/vault-init" --non-interactive
        "$INSTALL_PATH/bin/vault-ai-context"
        "$INSTALL_PATH/bin/vault-ext" run-hook post-update >/dev/null 2>&1 || true
    )

    log_success "✅ Project refresh completed for: $project_dir"
}

log_info "🔄 Checking for AI Shadow Vault updates..."

cd "$INSTALL_PATH" || exit 1

git fetch origin main -q

LOCAL=$(git rev-parse HEAD)
REMOTE=$(git rev-parse @{u})

if [ "$LOCAL" = "$REMOTE" ]; then
    log_success "✨ You are already on the latest version!"

    if project_context_available "$CALLER_DIR"; then
        run_post_update "$CALLER_DIR"
    else
        log_warn "ℹ️  No current project detected. Skipping project refresh."
    fi

    log_warn "💡 Reload only AI Shadow Vault with: source ~/.ai-shadow-vault/scripts/shell_integration.zsh"
    log_warn "💡 Or open a new terminal tab/window."
    exit 0
fi

echo -e "${YELLOW}🎁 New update found! What's new:${NC}"
echo "------------------------------------------"
GIT_PAGER=cat git log HEAD..origin/main --oneline --pretty=format:"%C(yellow)▶ %s %C(reset)(%cr)"
echo -e "\n------------------------------------------"

log_info "📥 Downloading and applying updates..."
git pull origin main -q

log_success "✅ Update successful!"

if project_context_available "$CALLER_DIR"; then
    run_post_update "$CALLER_DIR"
else
    log_warn "ℹ️  No current project detected. Skipping project refresh."
fi

log_warn "💡 Reload only AI Shadow Vault with: source ~/.ai-shadow-vault/scripts/shell_integration.zsh"
log_warn "💡 Or open a new terminal tab/window."
