#!/bin/bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/common.sh"
source "$SCRIPT_DIR/../lib/config.sh"
source "$SCRIPT_DIR/../lib/ui.sh"

show_help() {
    ai_vault_print_header "Keep context out of Git"
    cat <<'EOF'

Commands:
  ai-vault install   Run first-run setup or reconfigure global settings
  ai-vault init      Link the current project to the configured vault
  ai-vault update    Update AI Shadow Vault
EOF
}

subcommand="${1:-}"

case "$subcommand" in
    "")
        if ! ai_vault_config_exists; then
            exec "$SCRIPT_DIR/../scripts/install.sh"
        fi
        show_help
        ;;
    install)
        shift
        exec "$SCRIPT_DIR/../scripts/install.sh" "$@"
        ;;
    init)
        shift
        exec "$SCRIPT_DIR/../scripts/init.sh" "$@"
        ;;
    update)
        shift
        exec "$SCRIPT_DIR/../scripts/update.sh" "$@"
        ;;
    help|-h|--help)
        show_help
        ;;
    *)
        echo "Unknown command: $subcommand" >&2
        echo >&2
        show_help >&2
        exit 1
        ;;
esac
